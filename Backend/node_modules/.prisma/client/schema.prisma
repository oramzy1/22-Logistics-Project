generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  INDIVIDUAL
  BUSINESS
  DRIVER
  ADMIN
}

model User {
  id                 String           @id @default(uuid())
  email              String           @unique
  password           String
  name               String
  role               Role             @default(INDIVIDUAL)
  phone              String?
  isVerified         Boolean          @default(false)
  verificationToken  String?
  verificationExpiry DateTime?
  resetToken         String?
  resetTokenExpiry   DateTime?
  businessProfile    BusinessProfile?
  driverProfile      DriverProfile?
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  avatarUrl          String?

  pushToken String? // for Expo push notifications

  bookingsAsCustomer Booking[]      @relation("CustomerBookings")
  bookingsAsDriver   Booking[]      @relation("DriverBookings")
  notifications      Notification[]
  reviewsAsDriver    DriverReview[] @relation("DriverReviews")
  reviewsAsCustomer  DriverReview[] @relation("CustomerReviews")
}

model BusinessProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  companyName    String
  companyEmail   String
  companyAddress String
  companyPhone   String
  adminName      String
  adminEmail     String
  department     String?
  adminPhone     String
  scheduleType   String   @default("others")
  cacNumber      String?
  logoUrl        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Booking {
  id         String  @id @default(uuid())
  customerId String
  customer   User    @relation("CustomerBookings", fields: [customerId], references: [id])
  driverId   String?
  driver     User?   @relation("DriverBookings", fields: [driverId], references: [id])

  pickupAddress  String
  dropoffAddress String
  pickupLat      Float?
  pickupLng      Float?
  dropoffLat     Float?
  dropoffLng     Float?

  scheduledAt DateTime
  duration    Int?
  packageType String?

  status             BookingStatus @default(PENDING)
  paymentStatus      PaymentStatus @default(UNPAID)
  paymentRef         String?       @unique
  paystackAccessCode String?

  totalAmount        Float
  notes              String?
  cancellationReason String?
  refundRequested    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rideRequests  RideRequest[]
  notifications Notification[]
  extensions    TripExtension[]
  review        DriverReview?
}

model TripExtension {
  id                 String   @id @default(uuid())
  bookingId          String
  booking            Booking  @relation(fields: [bookingId], references: [id])
  hours              Int
  amount             Int
  paymentRef         String   @unique
  paymentStatus      String   @default("UNPAID") // UNPAID | PAID
  paystackAccessCode String?
  createdAt          DateTime @default(now())
}

model DriverReview {
  id         String   @id @default(uuid())
  bookingId  String   @unique // one review per booking
  booking    Booking  @relation(fields: [bookingId], references: [id])
  driverId   String
  driver     User     @relation("DriverReviews", fields: [driverId], references: [id])
  customerId String
  customer   User     @relation("CustomerReviews", fields: [customerId], references: [id])
  rating     Int // 1-5
  comment    String?
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id])
  title     String
  body      String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model DriverProfile {
  id              String        @id @default(uuid())
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id])
  licenseNumber   String?
  licenseImageUrl String?
  licenseStatus   LicenseStatus @default(PENDING)
  isOnline        Boolean       @default(false)
  isAvailable     Boolean       @default(false) // online AND ready for assignment
  currentLat      Float?
  currentLng      Float?
  totalTrips      Int           @default(0)
  acceptanceRate  Float         @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  vehicleType     String?
  brandModel      String?
  plateNumber     String?
  vehicleColor    String?

  workingHours String? @default("8:00 AM - 5:00 PM")
  onlineStatus String  @default("OFFLINE") // "ONLINE", "AWAY", "OFFLINE"

  rideRequests RideRequest[]
}

model RideRequest {
  id              String            @id @default(uuid())
  bookingId       String
  booking         Booking           @relation(fields: [bookingId], references: [id])
  driverProfileId String
  driverProfile   DriverProfile     @relation(fields: [driverProfileId], references: [id])
  status          RideRequestStatus @default(PENDING)
  expiresAt       DateTime // request expires after 30s if no response
  respondedAt     DateTime?
  createdAt       DateTime          @default(now())
}

enum LicenseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RideRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum BookingStatus {
  PENDING // just created, unpaid
  AWAITING_DRIVER // paid, waiting for driver assignment
  ACCEPTED // driver assigned/accepted
  IN_PROGRESS // ride started
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}
