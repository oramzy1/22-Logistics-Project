generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  INDIVIDUAL
  BUSINESS
  DRIVER
  ADMIN
}

model User {
  id                 String           @id @default(uuid())
  email              String           @unique
  password           String?
  name               String
  role               Role             @default(INDIVIDUAL)
  phone              String?
  isVerified         Boolean          @default(false)
  verificationToken  String?
  verificationExpiry DateTime?
  resetToken         String?
  resetTokenExpiry   DateTime?
  businessProfile    BusinessProfile?
  driverProfile      DriverProfile?
  isDeleted          Boolean          @default(false)
  deletedAt          DateTime?
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  avatarUrl          String?
  authProvider       String           @default("email") // "email" | "google" | "apple" | "hybrid"
  actionOtp          String?
  actionOtpExpiry    DateTime?
  pendingEmail       String? // new email awaiting verification
  pendingPassword    String? // hashed password awaiting email confirmation
  pendingEmailToken  String? // hashed OTP for new email verification
  pendingEmailExpiry DateTime?
  auditLogs          AdminAuditLog[]  @relation("AdminAuditLogs")

  pushToken String? // for Expo push notifications

  bookingsAsCustomer Booking[]        @relation("CustomerBookings")
  bookingsAsDriver   Booking[]        @relation("DriverBookings")
  notifications      Notification[]
  reviewsAsDriver    DriverReview[]   @relation("DriverReviews")
  reviewsAsCustomer  DriverReview[]   @relation("CustomerReviews")
  supportTickets     SupportTicket[]
  supportMessages    SupportMessage[]
}

model BusinessProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  companyName    String
  companyEmail   String
  companyAddress String
  companyPhone   String
  adminName      String
  adminEmail     String
  department     String?
  adminPhone     String
  scheduleType   String   @default("others")
  cacNumber      String?
  logoUrl        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Booking {
  id         String  @id @default(uuid())
  customerId String
  customer   User    @relation("CustomerBookings", fields: [customerId], references: [id])
  driverId   String?
  driver     User?   @relation("DriverBookings", fields: [driverId], references: [id], onDelete: SetNull)

  pickupAddress  String
  dropoffAddress String
  pickupLat      Float?
  pickupLng      Float?
  dropoffLat     Float?
  dropoffLng     Float?

  scheduledAt        DateTime
  duration           String?
  packageType        String?
  trackingId         String?   @unique
  pickupDate         String?
  pickupTime         String?
  outsidePH          Boolean?  @default(false)
  addOns             String[]
  rideType           Role
  acceptedByDriverAt DateTime?

  status             BookingStatus @default(PENDING)
  paymentStatus      PaymentStatus @default(UNPAID)
  paymentRef         String?       @unique
  paystackAccessCode String?

  totalAmount        Float
  notes              String?
  cancellationReason String?
  refundRequested    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rideRequests  RideRequest[]
  notifications Notification[]
  extensions    TripExtension[]
  review        DriverReview?
}

model TripExtension {
  id                 String   @id @default(uuid())
  bookingId          String
  booking            Booking  @relation(fields: [bookingId], references: [id])
  hours              Int
  amount             Int
  paymentRef         String   @unique
  paymentStatus      String   @default("UNPAID") // UNPAID | PAID
  paystackAccessCode String?
  createdAt          DateTime @default(now())
}

model DriverReview {
  id         String   @id @default(uuid())
  bookingId  String   @unique // one review per booking
  booking    Booking  @relation(fields: [bookingId], references: [id])
  driverId   String
  driver     User     @relation("DriverReviews", fields: [driverId], references: [id])
  customerId String
  customer   User     @relation("CustomerReviews", fields: [customerId], references: [id])
  rating     Int // 1-5
  comment    String?
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id])
  title     String
  body      String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model DriverProfile {
  id              String        @id @default(uuid())
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id])
  licenseNumber   String?
  licenseImageUrl String?
  licenseStatus   LicenseStatus @default(PENDING)
  isOnline        Boolean       @default(false)
  isAvailable     Boolean       @default(false) // online AND ready for assignment
  currentLat      Float?
  currentLng      Float?
  totalTrips      Int           @default(0)
  acceptanceRate  Float         @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  vehicleType     String?
  brandModel      String?
  plateNumber     String?
  vehicleColor    String?

  workingHours String? @default("8:00 AM - 5:00 PM")
  onlineStatus String  @default("OFFLINE") // "ONLINE", "AWAY", "OFFLINE"
  rating       Float   @default(5.0)

  rideRequests RideRequest[]
}

model RideRequest {
  id              String            @id @default(uuid())
  bookingId       String
  booking         Booking           @relation(fields: [bookingId], references: [id])
  driverProfileId String
  driverProfile   DriverProfile     @relation(fields: [driverProfileId], references: [id])
  status          RideRequestStatus @default(PENDING)
  expiresAt       DateTime // request expires after 30s if no response
  respondedAt     DateTime?
  createdAt       DateTime          @default(now())
}

model AppSettings {
  id        String   @id @default(uuid())
  key       String   @unique // e.g. "price_3_hours", "extension_1_hour"
  value     String // stored as string, parsed by consumers
  label     String? // human-readable label for admin UI
  updatedAt DateTime @updatedAt
  updatedBy String? // adminId
}

model PromoCode {
  id               String       @id @default(uuid())
  code             String       @unique
  description      String?
  discountType     DiscountType @default(PERCENTAGE)
  discountValue    Float // e.g. 10 = 10% or 10 = ₦10,000
  minBookingAmount Float? // minimum booking amount to apply
  maxDiscount      Float? // cap for percentage discounts
  usageLimit       Int? // null = unlimited
  usedCount        Int          @default(0)
  isActive         Boolean      @default(true)
  expiresAt        DateTime?
  targetType       PromoTarget  @default(ALL)
  targetUserIds    String[] // for USER_SPECIFIC promos
  targetRole       Role? // for role-specific promos (INDIVIDUAL/BUSINESS)
  createdBy        String // adminId
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  usages           PromoUsage[]
}

model PromoUsage {
  id             String    @id @default(uuid())
  promoId        String
  promo          PromoCode @relation(fields: [promoId], references: [id])
  userId         String
  bookingId      String?
  discountAmount Float
  createdAt      DateTime  @default(now())
}

model AdminAuditLog {
  id         String   @id @default(uuid())
  adminId    String
  admin      User     @relation("AdminAuditLogs", fields: [adminId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  action     String // e.g. "DEACTIVATE_USER", "UPDATE_PRICE", "VERIFY_LICENSE"
  targetType String // "USER" | "BOOKING" | "DRIVER" | "SETTINGS"
  targetId   String?
  metadata   Json? // any extra context
  createdAt  DateTime @default(now())
}

model SupportTicket {
  id            String           @id @default(uuid())
  ticketId      String           @unique // e.g. TKT-001
  userId        String
  user          User             @relation(fields: [userId], references: [id])
  subject       String
  category      SupportCategory
  priority      TicketPriority   @default(MEDIUM)
  status        TicketStatus     @default(OPEN)
  screenshotUrl String?
  messages      SupportMessage[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model SupportMessage {
  id        String        @id @default(uuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id])
  senderId  String
  sender    User          @relation(fields: [senderId], references: [id])
  body      String
  isAdmin   Boolean       @default(false)
  createdAt DateTime      @default(now())
}

enum SupportCategory {
  PAYMENT
  DRIVER
  TRIP
  ACCOUNT
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum PromoTarget {
  ALL
  INDIVIDUAL
  BUSINESS
  USER_SPECIFIC
}

enum LicenseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RideRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum BookingStatus {
  PENDING // just created, unpaid
  AWAITING_DRIVER // paid, waiting for driver assignment
  ACCEPTED // driver assigned/accepted
  IN_PROGRESS // ride started
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}
